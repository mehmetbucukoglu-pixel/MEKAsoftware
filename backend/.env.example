# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/klinikapp"

# ==========================================
# AUTH
# ==========================================
JWT_SECRET="your-very-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="another-very-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ==========================================
# n8n INTEGRATION
# ==========================================

# A shared secret between your backend and n8n.
# Set the same value here AND in n8n's webhook header (x-n8n-secret).
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET="your-random-secret-here"

# The n8n Webhook URL that receives outbound messages from the app
# and sends them via WhatsApp Cloud API.
# In n8n: Add a "Webhook" trigger node → copy the Production URL → paste here.
# Example: https://your-n8n-domain.com/webhook/send-whatsapp
N8N_OUTBOUND_WEBHOOK_URL=""

# ==========================================
# APP
# ==========================================
PORT=3001
FRONTEND_URL="http://localhost:3000"
