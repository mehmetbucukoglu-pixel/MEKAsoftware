    // --- Private ---

    private async checkConflict(clinicId: string, doctorId: string, startTime: Date, endTime: Date, excludeId?: string) {
        const where: any = {
            clinicId,
            doctorId,
            status: 'CONFIRMED',
            startTime: { lt: endTime },
            endTime: { gt: startTime },
