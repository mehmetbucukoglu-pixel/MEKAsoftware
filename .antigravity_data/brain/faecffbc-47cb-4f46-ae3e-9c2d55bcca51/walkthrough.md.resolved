   ============================================ */

:root {
  /* Primary - Teal/Cyan for medical feel */
  --primary: #06b6d4;
  --primary-hover: #22d3ee;
  --primary-muted: rgba(6, 182, 212, 0.15);

  /* Accent - Violet for highlights */
  --accent: #8b5cf6;
  --accent-hover: #a78bfa;

  /* Backgrounds */
  --bg-base: #0a0e1a;
  --bg-surface: #111827;
  --bg-elevated: #1e293b;
  --bg-hover: #283548;
  --bg-card: #151d2e;

  /* Borders */
  --border: #1e293b;
  --border-hover: #334155;
  --border-focus: #06b6d4;

  /* Text */
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --text-inverse: #0f172a;

  /* Status Colors */
  --success: #10b981;
  --warning: #f59e0b;
  --error: #ef4444;
  --info: #3b82f6;

  /* Sidebar */
  --sidebar-width: 260px;
